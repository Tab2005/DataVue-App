# ============================================================
# DataVue Backend 環境變數範本
# ============================================================
# 複製此文件為 .env 並填入真實值：
#   cp .env.example .env
#
# ⚠️  警告：.env 絕對不能提交至 Git！
# ⚠️  本文件（.env.example）不含真實值，可安全提交。
# ============================================================

# === 安全加密金鑰（必填）===
# 使用 Fernet 生成：
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-encryption-key-here

# === Google OAuth（必填）===
# 至 Google Cloud Console > API & Services > Credentials 取得
# https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Required for Google Search Console integration (OAuth token exchange)
GOOGLE_CLIENT_SECRET=your-google-client-secret

# === 超級管理員設定（必填）===
# 第一位登入的帳號會自動升為 Super Admin
# 支援逗號分隔多個 Email：admin1@example.com,admin2@example.com
SUPER_ADMIN_EMAIL=your-admin-email@example.com

# === 資料庫設定（選填，預設使用 SQLite）===
# 開發環境（SQLite，預設）：
# DATABASE_URL=sqlite:///./facebook_dashboard.db
#
# 生產環境（PostgreSQL，建議）：
# DATABASE_URL=postgresql://user:password@host:5432/datavue
DATABASE_URL=

# === AI 服務設定（選填）===
# Zeabur AI Hub：https://zeabur.com/
ZEABUR_AI_HUB_API_KEY=your-zeabur-ai-hub-api-key

# Google Gemini AI：https://aistudio.google.com/
GOOGLE_AI_API_KEY=your-google-ai-api-key

# === 應用設定（選填）===
# 環境類型：development | production
ENV=development

# 是否在目前程序啟用 APScheduler。
# 若雲端要拆成獨立 scheduler worker，請在 web service 設為 false，worker 設為 true。
ENABLE_REPORT_SCHEDULER=true
