# ============================================================
# DataVue Backend 環境變數範本
# ============================================================
# 複製此文件為 .env 並填入真實值：
#   cp .env.example .env
#
# ⚠️  警告：.env 絕對不能提交至 Git！
# ⚠️  本文件（.env.example）不含真實值，可安全提交。
# ============================================================

# === 安全加密金鑰（必填）===
# 使用 Fernet 生成：
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-encryption-key-here

# === Google OAuth（必填）===
# 至 Google Cloud Console > API & Services > Credentials 取得
# https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Required for Google Search Console integration (OAuth token exchange)
GOOGLE_CLIENT_SECRET=your-google-client-secret

# === 超級管理員設定（必填）===
# 第一位登入的帳號會自動升為 Super Admin
# 支援逗號分隔多個 Email：admin1@example.com,admin2@example.com
SUPER_ADMIN_EMAIL=your-admin-email@example.com

# === 資料庫設定（選填，預設使用 SQLite）===
# 開發環境（SQLite，預設）：
# DATABASE_URL=sqlite:///./facebook_dashboard.db
#
# 生產環境（PostgreSQL，建議）：
# DATABASE_URL=postgresql://user:password@host:5432/datavue
DATABASE_URL=

# === AI 服務設定（選填）===
# Zeabur AI Hub：https://zeabur.com/
ZEABUR_AI_HUB_API_KEY=your-zeabur-ai-hub-api-key

# Google Gemini AI：https://aistudio.google.com/
GOOGLE_AI_API_KEY=your-google-ai-api-key

# === 應用設定（選填）===
# 環境類型：development | production
ENV=development

# 是否在目前程序啟用 APScheduler。
# 若雲端要拆成獨立 scheduler worker，請在 web service 設為 false，worker 設為 true。
ENABLE_REPORT_SCHEDULER=true

# === Meta Andromeda Storage（選填）===
# filesystem: 本機落檔；s3_compatible: shared object storage（S3 / MinIO）
META_ANDROMEDA_STORAGE_BACKEND=filesystem
META_ANDROMEDA_STORAGE_ROOT=
META_ANDROMEDA_STORAGE_KEY_PREFIX=meta-andromeda
# 若有反向代理 / CDN 可公開這個 base URL，回傳 payload 會帶出 public_url
META_ANDROMEDA_STORAGE_PUBLIC_BASE_URL=
META_ANDROMEDA_STORAGE_S3_BUCKET=
META_ANDROMEDA_STORAGE_S3_REGION=
META_ANDROMEDA_STORAGE_S3_ENDPOINT_URL=
META_ANDROMEDA_STORAGE_S3_ACCESS_KEY_ID=
META_ANDROMEDA_STORAGE_S3_SECRET_ACCESS_KEY=

# === Meta Andromeda Scoring Runtime（選填）===
# auto: 有 GOOGLE_AI_API_KEY 時走 Gemini，否則自動回退到 heuristic provider
# heuristic: 永遠使用本地 deterministic provider
# gemini: 強制使用 Gemini provider；若呼叫失敗則依 META_ANDROMEDA_SCORING_ALLOW_FALLBACK 決定是否回退
META_ANDROMEDA_SCORING_PROVIDER=auto
META_ANDROMEDA_SCORING_MODEL_VERSION=cand_v2026_06_05_a
META_ANDROMEDA_SCORING_MODEL=models/gemini-2.0-flash
META_ANDROMEDA_SCORING_ALLOW_FALLBACK=true
META_ANDROMEDA_SCORE_TIMEOUT_SECONDS=20
META_ANDROMEDA_SCORE_MAX_ATTEMPTS=3
META_ANDROMEDA_SCORE_RETRY_DELAY_SECONDS=5
META_ANDROMEDA_SCORE_LOCAL_ASYNC_FALLBACK=true
META_ANDROMEDA_QUEUE_HOST=auto
META_ANDROMEDA_QUEUE_SWEEP_INTERVAL_SECONDS=5
META_ANDROMEDA_REDIS_STREAM_KEY=meta_andromeda:score_queue
META_ANDROMEDA_REDIS_STREAM_GROUP=meta_andromeda_workers
META_ANDROMEDA_REDIS_STREAM_CONSUMER=datavue-consumer
META_ANDROMEDA_REDIS_STREAM_BATCH_SIZE=20
META_ANDROMEDA_REDIS_STREAM_RECLAIM_IDLE_MS=30000
META_ANDROMEDA_REDIS_STREAM_RECLAIM_BATCH_SIZE=20
META_ANDROMEDA_EXTERNAL_QUEUE_ENDPOINT=
META_ANDROMEDA_EXTERNAL_QUEUE_TOKEN=
META_ANDROMEDA_EXTERNAL_QUEUE_TIMEOUT_SECONDS=10
META_ANDROMEDA_EXTERNAL_QUEUE_SIGNING_SECRET=
META_ANDROMEDA_EXTERNAL_WORKER_SHARED_SECRET=
META_ANDROMEDA_EXTERNAL_WORKER_TOKEN=
