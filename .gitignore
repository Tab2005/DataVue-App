# General
.DS_Store
node_modules/
venv/
.venv/
env/
__pycache__/
*.py[cod]
*.pyo
*.pyc
.idea/
.vscode/settings.json
*.swp
*.swo
scratch/

# 敏感設定檔（絕對不能提交）
.env
.env.local
.env.*.local
backend/.env
backend/.env.*
!backend/.env.example  # 範例檔案可安全提交

# 日誌檔
*.log
debug_*.log
backend/debug_*.log
# 備份與臨時文件
*.backup
*.bak
*.orig
*_orig.*
*_backup.*
*.tmp
Thumbs.db
# Backend specific
backend/tokens.json
backend/__pycache__/
backend/venv/

# 資料庫文件
*.db
*.sqlite
*.sqlite3
backend/*.db

# 測試與覆蓋率
.coverage
htmlcov/
.pytest_cache/
*.egg-info/

# 建置產物
dist/
build/

# Frontend specific
frontend/node_modules/
frontend/dist/
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# We DO want to commit the template .env files if they exist, but not the actual ones with secrets
# unless they are explicitly named differently.
# For this project, we are using .env for secrets in backend, so it's ignored.
